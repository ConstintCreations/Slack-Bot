{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "Fishing Game"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": false,
      "messages_tab_read_only_enabled": true
    },
    "bot_user": {
      "display_name": "Fishing Game",
      "always_online": true
    },
    "shortcuts": [],
    "slash_commands": [
      {
        "command": "/cast",
        "description": "Cast your rod!",
        "should_escape": false
      },
      {
        "command": "/reel",
        "description": "Reel in your fish!",
        "should_escape": false
      },
      {
        "command": "/sell",
        "description": "Sell your haul!",
        "should_escape": false
      },
      {
        "command": "/fishdex",
        "description": "View your caught fish!",
        "usage_hint": "User",
        "should_escape": false
      },
      {
        "command": "/shop",
        "description": "Opens the shop!",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "chat:write",
        "commands",
        "reactions:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_home_opened"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
